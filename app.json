{
  "expo": {
    "name": "CalculadoraEletricaResidencial",
    "slug": "CalculadoraEletricaResidencial",
    "version": "1.4.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "calculadoraeletricaresidencial",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.apsantosf.CalculadoraEletricaResidencial"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b24445fb-366e-461f-8ab1-3d3925a9f91e"
      }
    }
  }
}
